{
  "name": "clinica",
  "version": "1.0.9",
  "description": "Sistema de clinica empaquetado con Electron",
  "author": "Clinica",
  "repository": {
    "type": "git",
    "url": "https://example.invalid/clinica-electron"
  },
  "private": true,
  "main": "electron-app/main.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "stop": "node backend/scripts/stop-server.js",
    "install:backend": "npm --prefix backend install",
    "install:electron-app": "npm --prefix electron-app install",
    "electron": "electron electron-app/main.js",
    "electron:dev": "electron electron-app/main.js",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:win:local": "electron-builder --win --x64 --publish never --config.win.signAndEditExecutable=false --config.forceCodeSigning=false",
    "dist:mac": "electron-builder --mac --publish never"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "26.0.12"
  },
  "build": {
    "appId": "com.clinica.electron",
    "productName": "ClinicaElectron",
    "asar": true,
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "runtime/backend",
        "filter": [
          "**/*",
          "node_modules{,/**}",
          ".env"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "runtime/backend/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "frontend",
        "to": "runtime/frontend",
        "filter": [
          "**/*",
          "!img/docs{,/**}"
        ]
      },
      {
        "from": "runtime.package.json",
        "to": "runtime/package.json"
      }
    ],
    "directories": {
      "app": "electron-app",
      "output": "dist-electron"
    },
    "win": {
      "icon": "incisoft.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "build/icons/incisoft.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kpachgo",
        "repo": "clinicaElectron",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "installerIcon": "incisoft.ico",
      "uninstallerIcon": "incisoft.ico"
    },
    "disableDefaultIgnoredFiles": true
  }
}
